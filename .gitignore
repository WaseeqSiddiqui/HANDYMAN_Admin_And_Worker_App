# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
*.apk
*.aab
/android/app/build/

# Exclude text files (analysis, build logs, errors)
*.txt
# But keep CMakeLists.txt for platform builds
!**/CMakeLists.txt

# Exclude YAML files (analysis_options, etc.)
*.yaml
# But keep pubspec.yaml as it's essential for Flutter
!pubspec.yaml

# Exclude APK files
*.apk

# Exclude Firebase configuration (contains API keys)
lib/firebase_options.dart
**/google-services.json
**/GoogleService-Info.plist

# Exclude Android signing keys
*.jks
*.keystore
android/key.properties

# Exclude environment variable files
.env
.env.*
*.env

# Node modules (Cloud Functions dependencies)
**/node_modules/

# Ignore large analysis/build log files
analysis.txt
analysis_current.txt
analysis_final.txt
analysis_output.txt
analysis_report.txt
analysis_report_v2.txt
analysis_results.txt
analysis_results_final.txt
service_analysis.txt
worker_analysis.txt
worker_analysis_2.txt
errors.txt
errors_2.txt
errors_3.txt
build_log*.txt
